# Unity .gitignore (BGM CardBattle)
# 경로 앞에 '/'를 두지 않아 프로젝트가 루트든 하위 폴더(CardBattle/)든 어디서나 매칭됩니다.

# ----- Unity 생성 폴더 -----
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/
.utmp/

# ----- Unity 생성 파일 -----
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.tmp
*.log
sysinfo.txt
mono_crash.*
crashlytics-build.properties

# ----- 빌드 산출물 (Android/데스크톱) -----
*.apk
*.aab
*.ap_
*.app
*.unitypackage
*.unitypackage.meta

# ----- Android / Gradle / 서명키 (절대 커밋 금지) -----
.gradle/
*.keystore
*.jks

# ----- IDE (Visual Studio / Rider / VSCode) -----
*.csproj
*.sln
*.slnx
*.suo
*.user
*.userprefs
*.unityproj
ExportedObj/
.vs/
.vscode/
.idea/
*.iml
*.DotSettings
*.DotSettings.user
[Aa]ssets/Plugins/Editor/JetBrains*

# ----- AI 도구 / 비밀키 / 환경 -----
.claude/
.serena/
.playwright-mcp/
.env
.env.*
*.pem
*.key
*.p12
*.pfx

# ----- OS 캐시 -----
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# ----- 테스트 자동 생성 씬 -----
[Ii]nit[Tt]est[Ss]cene*.unity*
